[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/hub/home_hub.gd" id="1"]

[node name="HomeHub" type="CanvasLayer"]
script = ExtResource("1")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 200
offset_top = 50
offset_right = -200
offset_bottom = -50

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2

[node name="Header" type="HBoxContainer" parent="Panel/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="Panel/VBox/Header"]
layout_mode = 2
text = "Home Hub"
size_flags_horizontal = 3

[node name="CloseBtn" type="Button" parent="Panel/VBox/Header"]
layout_mode = 2
text = "Close [Esc]"

[node name="Tabs" type="TabContainer" parent="Panel"]
layout_mode = 2
offset_left = 10
offset_top = 40
offset_right = -10
offset_bottom = -10

[node name="Shop" type="VBoxContainer" parent="Panel/Tabs"]
layout_mode = 2

[node name="ShopTitle" type="Label" parent="Panel/Tabs/Shop"]
layout_mode = 2
text = "Shop - Buy with carried gold"

[node name="ScrollContainer" type="ScrollContainer" parent="Panel/Tabs/Shop"]
layout_mode = 2
size_flags_vertical = 3

[node name="ShopList" type="VBoxContainer" parent="Panel/Tabs/Shop/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Bank" type="VBoxContainer" parent="Panel/Tabs"]
layout_mode = 2

[node name="BankGoldLabel" type="Label" parent="Panel/Tabs/Bank"]
layout_mode = 2
text = "Bank: 0g"

[node name="CarriedGoldLabel" type="Label" parent="Panel/Tabs/Bank"]
layout_mode = 2
text = "Carried: 0g"

[node name="DepositAllBtn" type="Button" parent="Panel/Tabs/Bank"]
layout_mode = 2
text = "Deposit All"

[node name="Status" type="VBoxContainer" parent="Panel/Tabs"]
layout_mode = 2

[node name="HealthLabel" type="Label" parent="Panel/Tabs/Status"]
layout_mode = 2
text = "HP: Full"

[node name="RegenLabel" type="Label" parent="Panel/Tabs/Status"]
layout_mode = 2
text = "Regen: Active (Sanctuary)"

[connection signal="pressed" from="Panel/VBox/Header/CloseBtn" to="." method="_on_close_pressed"]
[connection signal="pressed" from="Panel/Tabs/Bank/DepositAllBtn" to="." method="_on_deposit_all_pressed"]
