; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TheLongWalk"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")

[audio]

buses/default_bus_layout="res://audio_buses.tres"

[autoload]

GameState="*res://autoload/game_state.gd"
DataStore="*res://autoload/data_store.gd"
SettingsManager="*res://autoload/settings_manager.gd"

[debug]

gdscript/warnings/class_name_hides_autoload=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/initial_position_type=2
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

